# ============================================================
# DermaScreen Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your actual values.
# DO NOT commit the .env file to version control.
# ============================================================

# ---------- Supabase ----------
# Get these from: https://app.supabase.com → Project Settings → API
SUPABASE_URL=# PUT YOUR SUPABASE PROJECT URL HERE (e.g. https://xxxxx.supabase.co)
SUPABASE_SERVICE_KEY=# PUT YOUR SUPABASE SERVICE ROLE KEY HERE (NOT the anon key)

# ---------- Firebase ----------
# Download your service account JSON from:
# Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Place the JSON file in backend/ and put the filename here
FIREBASE_SERVICE_ACCOUNT_PATH=# PUT YOUR FIREBASE SERVICE ACCOUNT JSON FILENAME HERE (e.g. firebase-service-account.json)

# ---------- OpenRouter (AI Chat) ----------
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=# PUT YOUR OPENROUTER API KEY HERE
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# ---------- ML Model ----------
# Place your .pkl model file in backend/models/ folder
ML_MODEL_PATH=models/model.pkl

# ---------- Server ----------
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
